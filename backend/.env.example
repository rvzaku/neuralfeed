DATABASE_URL=sqlite+aiosqlite:///./neuralFeed.db
ARXIV_API_BASE=https://export.arxiv.org/api/query
REDDIT_USER_AGENT=NeuralFeed/0.1 (personal; contact: you@example.com)
GITHUB_TOKEN=
TWITTER_BEARER_TOKEN=
HF_API_TOKEN=

# Scheduled fetching (in-process APScheduler)
SCHEDULER_ENABLED=true

# LinkedIn public-page bridge — RSSHub instance (public default; self-host for reliability)
RSSHUB_BASE=https://rsshub.app

# Feed freshness — no source waits longer than this many hours between fetches
REFRESH_MAX_HOURS=4

# Summaries — groq (default, free key at console.groq.com) or ollama (local)
SUMMARY_PROVIDER=groq
SUMMARY_MODEL=
# Model for rewriting slug titles into plain-English headlines (defaults to the
# stronger 70b model for title quality; override to a faster one if the backlog lags)
ENRICH_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Daily "Today in AI" email digest (P1.4). Leave RESEND_API_KEY empty to disable
# sending — the in-app Today page still works. Users opt in per-account in
# Settings. From-address must be a verified Resend sender (or onboarding@resend.dev).
RESEND_API_KEY=
DIGEST_FROM_EMAIL=NeuralFeed <onboarding@resend.dev>
DIGEST_SEND_HOUR_UTC=6
APP_BASE_URL=https://neuralfeed.vercel.app

# CORS — origins allowed to call the API from a browser. Comma-separated or a
# JSON array. MUST include your deployed frontend's exact origin (no trailing
# slash) or the browser will block requests even though curl succeeds.
CORS_ORIGINS=http://localhost:3000,https://neuralfeed.vercel.app
# Optional regex for origins you can't enumerate (e.g. Vercel preview deploys).
# Keep it tightly anchored so it can't match foreign domains. Empty = disabled.
# CORS_ORIGIN_REGEX=^https://neuralfeed-[a-z0-9-]+\.vercel\.app$

# Read-only public guest mode (the "Browse as guest" button). Off by default.
GUEST_MODE_ENABLED=false
# Allow guests to trigger fresh LLM summaries (costs quota); capped per day below.
GUEST_SUMMARIES_ENABLED=false
GUEST_SUMMARY_DAILY_CAP=30

# Legacy Celery path only (unused at runtime)
REDIS_URL=redis://localhost:6379/0
